{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": ["github.com", "*.github.com"],
    "deniedDomains": ["gitlab.devstack.vwgroup.com"]
  },
  "filesystem": {
    "denyRead": ["/Users", "/home"],
    "allowRead": [
      ".",
      "~/.config",
      "~/.local",
      "~/Library",
      "/Users/fhslqoi/.local",
      "~/Library/Application Support/rtk"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "~/Library/Application Support/rtk",
      "/Users/fhslqoi/Library/Application Support/rtk"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ]
  }
}
