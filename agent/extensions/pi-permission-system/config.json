{
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "rm -rf *": "deny",
      "sudo *": "ask",
      "git *": "ask",
      "git push": "deny",
      "git log *": "allow",
      "git diff": "allow",
      "ssh *": "deny"
    },
    "external_directory": "ask"
  }
}
